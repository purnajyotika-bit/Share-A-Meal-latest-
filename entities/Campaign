{
  "name": "Campaign",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "goal_amount": {
      "type": "number"
    },
    "raised_amount": {
      "type": "number",
      "default": 0
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "image_url": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "food_rescue",
        "ngo_operations",
        "transport",
        "emergency_relief",
        "community_kitchen"
      ],
      "default": "food_rescue"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "completed"
      ],
      "default": "pending"
    },
    "is_emergency": {
      "type": "boolean",
      "default": false
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "creator_email": {
      "type": "string"
    },
    "creator_name": {
      "type": "string"
    },
    "donor_count": {
      "type": "number",
      "default": 0
    },
    "share_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "description",
    "goal_amount"
  ]
}
